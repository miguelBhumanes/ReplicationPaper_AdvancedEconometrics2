# ======================
# Python defaults
# ======================
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg

# ======================
# Virtual environments
# ======================
venv/
.env/
.envrc/

# .env file (may contain secrets)
.env

# ======================
# IDEs / editors
# ======================
.vscode/
.idea/
*.swp

# ======================
# OS files
# ======================
.DS_Store
Thumbs.db

# ======================
# Logs
# ======================
*.log

# ======================
# Raw / processed data — never commit
# ======================
data/raw/*
!data/raw/README.md
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep

# ======================
# Generated results — never commit
# ======================
results/figures/*
!results/figures/.gitkeep
results/tables/*
!results/tables/.gitkeep

# ======================
# Binary / large artifacts (loose, e.g. left in repo root)
# ======================
*.npz
*.png
*.pdf
*.xlsx
*.csv

# ======================
